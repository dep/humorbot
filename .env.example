# Slack app credentials (from https://api.slack.com/apps)
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Bot token (from OAuth & Permissions page, starts with xoxb-)
# If set, uses direct token auth instead of OAuth installation store
SLACK_BOT_TOKEN=

# Heroku Postgres (auto-set by Heroku Postgres addon)
DATABASE_URL=

# Optional
DEBUG_LOGGING=false

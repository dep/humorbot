# Slack app credentials (from https://api.slack.com/apps)
SLACK_SIGNING_SECRET=

# Bot token (from OAuth & Permissions page, starts with xoxb-)
SLACK_BOT_TOKEN=

# Client ID/Secret for OAuth flow (only needed for multi-workspace distribution)
# Uses HUMORBOT_ prefix to avoid Bolt's auto-detection of SLACK_CLIENT_ID
HUMORBOT_CLIENT_ID=
HUMORBOT_CLIENT_SECRET=

# Heroku Postgres (auto-set by Heroku Postgres addon)
DATABASE_URL=

# Optional
DEBUG_LOGGING=false
